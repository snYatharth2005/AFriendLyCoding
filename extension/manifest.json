{
  "manifest_version": 3,
  "name": "AFriendlyCoding Sync",
  "version": "1.0.0",
  "description": "Login and sync your LeetCode solved problems to AFriendlyCoding",

  "permissions": ["storage", "activeTab", "tabs", "scripting"],

  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AFriendlyCoding Sync"
  },

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
